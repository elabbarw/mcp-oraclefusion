# Oracle Fusion Cloud ERP connection
ORACLE_FUSION_BASE_URL=https://your-instance.fa.ocs.oraclecloud.com
ORACLE_USERNAME=your.name@example.com

# Auth option 1: Basic Auth (password)
ORACLE_PASSWORD=your_oracle_password

# Auth option 2: Oracle JWT (private key + certificate)
# If JWT vars are set, password is not required.
# ORACLE_JWT_PRIVATE_KEY_PATH=/path/to/private.pem
# ORACLE_JWT_PRIVATE_KEY=<inline PEM — alternative to path, useful in containers>
# ORACLE_JWT_CERT_PATH=/path/to/cert.pem
# ORACLE_JWT_ISSUER=your-trusted-issuer

# Optional: Oracle REST API version (default 11.13.18.05)
# ORACLE_FUSION_API_VERSION=11.13.18.05

# Optional: enable write tools (create POs, invoices, requisitions)
# MCP_MODE=full

# Optional: log level (default WARNING — logs go to stderr)
# LOG_LEVEL=INFO
